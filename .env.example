# CNPJ Data Pipeline Configuration

# Opção A: URL completa (sobrescreve DB_*)
# DATABASE_URL=postgres://postgres:postgres@localhost:5435/cnpj

# Opção B: mesmo padrão tce_utf82 / scfiplan (valores padrão no config se omitidos)
DB_HOST=IP
DB_PORT=PORTA
DB_NAME=BANCO
DB_USER=USER
DB_PASSWORD=PASSWORD

# Schema PostgreSQL onde ficam as tabelas do pipeline (search_path)
DB_SCHEMA=SCHEMA

# Processing
BATCH_SIZE=500000
TEMP_DIR=./temp

# Downloads (parallel)
DOWNLOAD_WORKERS=4

# Network
RETRY_ATTEMPTS=3
RETRY_DELAY=5
CONNECT_TIMEOUT=30
READ_TIMEOUT=300

# Cleanup
KEEP_DOWNLOADED_FILES=false
